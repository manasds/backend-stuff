# --- Redis (BullMQ) ---
# On Railway, reference the Redis service's private URL:
#   REDIS_URL=${{Redis.REDIS_URL}}
# Locally, leave unset to fall back to localhost:6379.
REDIS_URL=redis://localhost:6379

# --- HTTP server (API service only) ---
# Railway injects PORT automatically; only needed for local runs.
PORT=9999

# Allowed CORS origin for your frontend.
CORS_ORIGIN=http://localhost:3000

# --- Cloudflare R2 (shared object storage) ---
# From Cloudflare dashboard > R2. Create a bucket and an R2 API token.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name
# Optional: override the endpoint. Defaults to
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=

# How the API hands processed images back to clients:
# - By default it returns a time-limited *presigned* URL to the private bucket.
#   R2_URL_EXPIRES_IN sets how long (seconds) that URL is valid (max 604800 = 7d).
R2_URL_EXPIRES_IN=3600
# - If instead you expose the bucket via a public r2.dev URL or a custom domain,
#   set R2_PUBLIC_URL and the API will return a plain (non-signed) URL.
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
